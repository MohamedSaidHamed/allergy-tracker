{
  "expo": {
    "name": "Allergy Tracker",
    "slug": "seasonal-allergy-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seasonalallergytracker",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#1f2937"
      }
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allergy Tracker uses your location to show local pollen levels.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allergy Tracker uses your location in the background to send pollen spike alerts.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.mo.seasonal.allergy.tracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.mo.seasonal.allergy.tracker"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/38f6ba06-ec68-4b2c-ba0e-200159cc4844"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allergy Tracker uses your location to show local pollen levels and send spike alerts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3b82f6",
          "sounds": []
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": ""
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "GOOGLE_POLLEN_API_KEY": "",
      "OPEN_WEATHER_API_KEY": "",
      "router": {},
      "eas": {
        "projectId": "38f6ba06-ec68-4b2c-ba0e-200159cc4844"
      }
    }
  }
}
